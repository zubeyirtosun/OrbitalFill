{
  "manifest_version": 3,
  "name": "AutoFill Pro - Görev Odaklı Form Doldurucu",
  "commands": {
    "trigger-autofill": {
      "suggested_key": {
        "default": "Alt+A",
        "mac": "Command+Shift+A"
      },
      "description": "AutoFill menüsünü aç"
    }
  },
  "version": "1.0",
  "description": "Sık kullandığınız metinleri şablon olarak kaydedin ve formları saniyeler içinde doldurun.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content_script.js"],
      "css": ["src/content_styles.css"]
    }
  ],
  "options_page": "src/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
