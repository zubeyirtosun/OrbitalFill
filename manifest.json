{
  "manifest_version": 3,
  "name": "OrbitalFill Professional",
  "version": "1.6.7",
  "description": "Premium radial menu for form automation with Omnibox and Site Control.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file://*/*"
  ],
  "omnibox": { "keyword": "of" },
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
        "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file://*/*"],
      "js": ["src/content_script.js"],
      "css": ["src/content_styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_page": "src/options.html",
  "icons": {
    "128": "icons/icon128.png"
  }
}
